{"noir_version":"1.0.0-beta.6+e796dfd67726cbc28eb9991782533b211025928d","hash":"5670345927962380250","abi":{"parameters":[{"name":"secret","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"nonce","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"expected_hash","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"difficulty","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"timestamp","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"/// Deterministic mixing of secret, nonce, and difficulty (constraint-friendly on Noir 1.0).\npub fn compute_hash(secret: [u8; 32], nonce: [u8; 32], difficulty: u32) -> [u8; 32] {\n    let mut hash: [u8; 32] = [0; 32];\n    let d = difficulty as u8;\n    for i in 0..32 {\n        let rot = ((difficulty >> (i % 4)) & 0xff) as u8;\n        hash[i] = secret[i] ^ nonce[i] ^ d ^ rot ^ (i as u8);\n    }\n    hash\n}\n\n#[test]\nfn test_hash() {\n    let secret: [u8; 32] = [1; 32];\n    let nonce: [u8; 32] = [2; 32];\n    let _result = compute_hash(secret, nonce, 10);\n}\n","path":"/Users/shikharsingh/Downloads/code/zkverify-auth/zauth-captcha/circuits/src/hash.nr"},"51":{"source":"mod hash;\n\nfn main(\n    // Private inputs\n    secret: [u8; 32],\n    nonce: [u8; 32],\n    expected_hash: [u8; 32],  // The expected hash output (private)\n    \n    // Public inputs (only 2!)\n    difficulty: pub u32,\n    timestamp: pub u64\n) {\n    // Compute hash and verify it matches expected\n    let computed_hash = hash::compute_hash(secret, nonce, difficulty);\n    assert(computed_hash == expected_hash);\n    \n    // Timestamp unused\n    let _: u64 = timestamp;\n}\n","path":"/Users/shikharsingh/Downloads/code/zkverify-auth/zauth-captcha/circuits/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient"]}