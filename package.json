{
  "name": "@zauth/captcha-sdk",
  "version": "1.0.3",
  "description": "ZAuth Captcha SDK - Zero-knowledge proof based CAPTCHA for the modern web",
  "main": "dist/core.js",
  "module": "dist/core.mjs",
  "types": "dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "captcha",
    "zero-knowledge",
    "zk-proof",
    "privacy",
    "authentication",
    "bot-detection",
    "security",
    "noir",
    "web3",
    "blockchain",
    "react",
    "typescript"
  ],
  "author": "0xKryptonian <support@zauth.co>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zauth-HQ/captcha-sdk"
  },
  "bugs": {
    "url": "https://github.com/Zauth-HQ/captcha-sdk/issues"
  },
  "homepage": "https://github.com/Zauth-HQ/captcha-sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aztec/bb.js": "1.0.0",
    "@noir-lang/noir_js": "1.0.0-beta.11",
    "axios": "^1.6.5",
    "blakejs": "^1.2.1",
    "pako": "^2.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^19.2.3",
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
